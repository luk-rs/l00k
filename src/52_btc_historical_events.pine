// BTC Historical Events

l00kBtcEventsGroup = "BTC Historical Events"

l00kOnlyShowBtcEventsOnBtcCharts = input.bool(
     true,
     "Only Show BTC Events On BTC Charts",
     group = l00kBtcEventsGroup
)

l00kShowBtcHalvings = input.bool(true, "Show BTC Halvings", group = l00kBtcEventsGroup)
l00kShowBtcAthVerticals = input.bool(true, "Show BTC Vertical ATHs", group = l00kBtcEventsGroup)
l00kShowBtcEventLabels = input.bool(true, "Show BTC Event Labels", group = l00kBtcEventsGroup)
l00kBtcEventLineWidth = input.int(2, "BTC Event Line Width", minval = 1, maxval = 5, group = l00kBtcEventsGroup)

f_l00kUpdateVerticalLine(
     line existingLine,
     int lineTime,
     color lineColor,
     int lineWidth,
     bool visible
) =>
    line result = existingLine

    if visible
        if na(result)
            result := line.new(
                 x1 = lineTime,
                 y1 = low,
                 x2 = lineTime,
                 y2 = high,
                 xloc = xloc.bar_time,
                 extend = extend.both,
                 color = lineColor,
                 style = line.style_dashed,
                 width = lineWidth
            )
        else
            line.set_xy1(result, lineTime, low)
            line.set_xy2(result, lineTime, high)
            line.set_color(result, lineColor)
            line.set_width(result, lineWidth)
            line.set_style(result, line.style_dashed)
    else
        if not na(result)
            line.delete(result)
            result := na

    result

f_l00kUpdateVerticalLabel(
     label existingLabel,
     int labelTime,
     string labelText,
     color labelColor,
     color labelTextColor,
     bool visible,
     float labelY
) =>
    label result = existingLabel

    if visible
        if na(result)
            result := label.new(
                 x = labelTime,
                 y = labelY,
                 text = labelText,
                 xloc = xloc.bar_time,
                 style = label.style_label_up,
                 color = labelColor,
                 textcolor = labelTextColor,
                 size = size.small
            )
        else
            label.set_x(result, labelTime)
            label.set_y(result, labelY)
            label.set_text(result, labelText)
            label.set_color(result, labelColor)
            label.set_textcolor(result, labelTextColor)
    else
        if not na(result)
            label.delete(result)
            result := na

    result

l00kIsBtcChart = syminfo.basecurrency == "BTC"
l00kCanShowBtcEvents = not l00kOnlyShowBtcEventsOnBtcCharts or l00kIsBtcChart

l00kBtcHalvingLineColor = color.new(color.purple, 50)
l00kBtcHalvingLabelColor = color.new(color.purple, 50)
l00kBtcAthLineColor = color.new(color.yellow, 50)
l00kBtcAthLabelColor = color.new(color.yellow, 50)

l00kBtcEventLabelY = ta.lowest(low, 300)

int l00kHalving2012 = timestamp("UTC", 2012, 11, 28, 0, 0)
int l00kHalving2016 = timestamp("UTC", 2016, 7, 9, 0, 0)
int l00kHalving2020 = timestamp("UTC", 2020, 5, 11, 0, 0)
int l00kHalving2024 = timestamp("UTC", 2024, 4, 20, 0, 0)
int l00kHalving2028Estimate = timestamp("UTC", 2028, 4, 17, 0, 0)
int l00kHalving2032Estimate = timestamp("UTC", 2032, 4, 17, 0, 0)
int l00kHalving2036Estimate = timestamp("UTC", 2036, 4, 17, 0, 0)
int l00kHalving2040Estimate = timestamp("UTC", 2040, 4, 17, 0, 0)

int l00kBtcAth2013 = timestamp("UTC", 2013, 11, 30, 0, 0)
int l00kBtcAth2017 = timestamp("UTC", 2017, 12, 16, 0, 0)
int l00kBtcAth2021 = timestamp("UTC", 2021, 11, 10, 0, 0)
int l00kBtcAth2025 = timestamp("UTC", 2025, 10, 6, 0, 0)

var line l00kH2012Line = na
var line l00kH2016Line = na
var line l00kH2020Line = na
var line l00kH2024Line = na
var line l00kHNextEstimateLine = na

var label l00kH2012Label = na
var label l00kH2016Label = na
var label l00kH2020Label = na
var label l00kH2024Label = na
var label l00kHNextEstimateLabel = na

var line l00kBtcAth2013Line = na
var line l00kBtcAth2017Line = na
var line l00kBtcAth2021Line = na
var line l00kBtcAth2025Line = na

var label l00kBtcAth2013Label = na
var label l00kBtcAth2017Label = na
var label l00kBtcAth2021Label = na
var label l00kBtcAth2025Label = na

if barstate.islast
    bool l00kHalvingsVisible = l00kShowBtcHalvings and l00kCanShowBtcEvents
    bool l00kBtcAthsVisible = l00kShowBtcAthVerticals and l00kCanShowBtcEvents
    bool l00kBtcLabelsVisible = l00kShowBtcEventLabels and l00kCanShowBtcEvents

    int l00kNextHalvingEstimate = l00kHalving2040Estimate
    string l00kNextHalvingYear = "2040"

    if timenow < l00kHalving2028Estimate
        l00kNextHalvingEstimate := l00kHalving2028Estimate
        l00kNextHalvingYear := "2028"
    else if timenow < l00kHalving2032Estimate
        l00kNextHalvingEstimate := l00kHalving2032Estimate
        l00kNextHalvingYear := "2032"
    else if timenow < l00kHalving2036Estimate
        l00kNextHalvingEstimate := l00kHalving2036Estimate
        l00kNextHalvingYear := "2036"

    l00kH2012Line := f_l00kUpdateVerticalLine(l00kH2012Line, l00kHalving2012, l00kBtcHalvingLineColor, l00kBtcEventLineWidth, l00kHalvingsVisible)
    l00kH2016Line := f_l00kUpdateVerticalLine(l00kH2016Line, l00kHalving2016, l00kBtcHalvingLineColor, l00kBtcEventLineWidth, l00kHalvingsVisible)
    l00kH2020Line := f_l00kUpdateVerticalLine(l00kH2020Line, l00kHalving2020, l00kBtcHalvingLineColor, l00kBtcEventLineWidth, l00kHalvingsVisible)
    l00kH2024Line := f_l00kUpdateVerticalLine(l00kH2024Line, l00kHalving2024, l00kBtcHalvingLineColor, l00kBtcEventLineWidth, l00kHalvingsVisible)
    l00kHNextEstimateLine := f_l00kUpdateVerticalLine(l00kHNextEstimateLine, l00kNextHalvingEstimate, l00kBtcHalvingLineColor, l00kBtcEventLineWidth, l00kHalvingsVisible)

    string l00kNextHalvingIssuance = l00kNextHalvingYear == "2028" ? "1.5625 BTC/block" :
         l00kNextHalvingYear == "2032" ? "0.78125 BTC/block" :
         l00kNextHalvingYear == "2036" ? "0.390625 BTC/block" :
         "0.1953125 BTC/block"

    l00kH2012Label := f_l00kUpdateVerticalLabel(l00kH2012Label, l00kHalving2012, "BTC Halving\n2012\n25 BTC/block", l00kBtcHalvingLabelColor, color.white, l00kHalvingsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
    l00kH2016Label := f_l00kUpdateVerticalLabel(l00kH2016Label, l00kHalving2016, "BTC Halving\n2016\n12.5 BTC/block", l00kBtcHalvingLabelColor, color.white, l00kHalvingsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
    l00kH2020Label := f_l00kUpdateVerticalLabel(l00kH2020Label, l00kHalving2020, "BTC Halving\n2020\n6.25 BTC/block", l00kBtcHalvingLabelColor, color.white, l00kHalvingsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
    l00kH2024Label := f_l00kUpdateVerticalLabel(l00kH2024Label, l00kHalving2024, "BTC Halving\n2024\n3.125 BTC/block", l00kBtcHalvingLabelColor, color.white, l00kHalvingsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
    l00kHNextEstimateLabel := f_l00kUpdateVerticalLabel(l00kHNextEstimateLabel, l00kNextHalvingEstimate, "BTC Halving\n" + l00kNextHalvingYear + " est.\n" + l00kNextHalvingIssuance, l00kBtcHalvingLabelColor, color.white, l00kHalvingsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)

    l00kBtcAth2013Line := f_l00kUpdateVerticalLine(l00kBtcAth2013Line, l00kBtcAth2013, l00kBtcAthLineColor, l00kBtcEventLineWidth, l00kBtcAthsVisible)
    l00kBtcAth2017Line := f_l00kUpdateVerticalLine(l00kBtcAth2017Line, l00kBtcAth2017, l00kBtcAthLineColor, l00kBtcEventLineWidth, l00kBtcAthsVisible)
    l00kBtcAth2021Line := f_l00kUpdateVerticalLine(l00kBtcAth2021Line, l00kBtcAth2021, l00kBtcAthLineColor, l00kBtcEventLineWidth, l00kBtcAthsVisible)
    l00kBtcAth2025Line := f_l00kUpdateVerticalLine(l00kBtcAth2025Line, l00kBtcAth2025, l00kBtcAthLineColor, l00kBtcEventLineWidth, l00kBtcAthsVisible)

    l00kBtcAth2013Label := f_l00kUpdateVerticalLabel(l00kBtcAth2013Label, l00kBtcAth2013, "BTC ATH\n2013", l00kBtcAthLabelColor, color.black, l00kBtcAthsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
    l00kBtcAth2017Label := f_l00kUpdateVerticalLabel(l00kBtcAth2017Label, l00kBtcAth2017, "BTC ATH\n2017", l00kBtcAthLabelColor, color.black, l00kBtcAthsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
    l00kBtcAth2021Label := f_l00kUpdateVerticalLabel(l00kBtcAth2021Label, l00kBtcAth2021, "BTC ATH\n2021", l00kBtcAthLabelColor, color.black, l00kBtcAthsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
    l00kBtcAth2025Label := f_l00kUpdateVerticalLabel(l00kBtcAth2025Label, l00kBtcAth2025, "BTC ATH\n2025", l00kBtcAthLabelColor, color.black, l00kBtcAthsVisible and l00kBtcLabelsVisible, l00kBtcEventLabelY)
